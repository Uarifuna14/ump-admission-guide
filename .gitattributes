# Auto-detect text files and normalize line endings
* text=auto

# Ensure JavaScript/React files always use LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Ensure JSON and config files use LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-specific: keep batch files with CRLF
*.bat text eol=crlf

# Keep images and binaries untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary